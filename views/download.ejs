<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CYBERVAULT // PAYLOAD RETRIEVAL</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='85' fill='%230ea5e9'%3E⬡%3C/text%3E%3C/svg%3E">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,600;0,800;1,400&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #020b07;
      --surface: rgba(14, 165, 233, 0.03);
      --border: rgba(14, 165, 233, 0.15);
      --border-hot: rgba(14, 165, 233, 0.5);
      --blue: #0ea5e9;
      --blue-dim: #0284c7;
      --blue-muted: rgba(27, 176, 245, 0.45);
      --amber: #ffb300;
      --red: #ff2d55;
      --text: #ffffff;
      --text-muted: #bae6fd;
      --text-dim: #38bdf8;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    
    *:focus-visible {
      outline: 2px solid var(--blue);
      outline-offset: 2px;
    }

    body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: 'JetBrains Mono', monospace;
      display: grid;
      place-items: center;
      padding: 24px 16px;
      overflow-x: hidden;
    }

    /* Scanline effect removed by request */

    /* Grid bg */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(14,165,233,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(14,165,233,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .page {
      position: relative;
      z-index: 1;
      width: min(860px, 100%);
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--border);
      overflow: hidden;
      border-radius: 8px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    /* top glow line */
    .page::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--blue), transparent);
      animation: scan-top 4s ease-in-out infinite;
    }

    @keyframes scan-top {
      0%,100% { opacity: 0.3; } 50% { opacity: 1; }
    }

    /* ── TOPBAR ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 22px;
      border-bottom: 1px solid var(--border);
      background: rgba(14,165,233,0.04);
      flex-wrap: wrap;
      gap: 10px;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-mark {
      width: 30px; height: 30px;
      border: 1px solid var(--blue);
      display: grid; place-items: center;
      font-size: 14px;
      color: var(--blue);
      box-shadow: 0 0 12px rgba(14,165,233,0.25);
      animation: pulse-mark 2s ease-in-out infinite;
    }

    @keyframes pulse-mark {
      0%,100% { box-shadow: 0 0 8px rgba(14,165,233,0.2); }
      50% { box-shadow: 0 0 22px rgba(14,165,233,0.5); }
    }

    .logo-name {
      font-size: 0.85rem;
      font-weight: 800;
      color: var(--blue);
      letter-spacing: 0.14em;
      text-shadow: 0 0 20px rgba(14,165,233,0.5);
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .sys-chip {
      font-size: 0.72rem;
      color: var(--text-dim);
      letter-spacing: 0.12em;
    }

    .sys-chip span { color: var(--text-muted); }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 10px;
      border: 1px solid rgba(14,165,233,0.3);
      background: rgba(14,165,233,0.05);
      font-size: 0.62rem;
      letter-spacing: 0.15em;
      color: var(--blue);
      text-transform: uppercase;
    }

    .dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--blue);
      box-shadow: 0 0 5px var(--blue);
      animation: blink 1.2s step-start infinite;
    }

    @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

    /* ── HERO ── */
    .hero {
      padding: 32px 28px 28px;
      border-bottom: 1px solid var(--border);
      background: rgba(0,0,0,0.2);
      position: relative;
      overflow: hidden;
    }

    .hero-corner {
      position: absolute;
      top: 0; right: 0;
      width: 200px; height: 200px;
      background: radial-gradient(circle at top right, rgba(14,165,233,0.06), transparent 70%);
      pointer-events: none;
    }

    .eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .eyebrow::before { content: '//'; color: var(--text-dim); }

    .hero-title {
      font-size: clamp(1.8rem, 5vw, 3.4rem);
      font-weight: 800;
      line-height: 0.95;
      color: var(--blue);
      text-shadow: 0 0 40px rgba(14,165,233,0.3);
      letter-spacing: 0.04em;
      margin-bottom: 14px;
    }

    .hero-sub {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.75;
      letter-spacing: 0.04em;
      max-width: 520px;
    }

    /* ── CONTENT ── */
    .content {
      padding: 24px 28px;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    /* ── ALERT ── */
    .alert {
      padding: 12px 18px;
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      line-height: 1.65;
      border-left: 2px solid;
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .alert-icon { flex-shrink: 0; }

    .alert.success {
      background: rgba(14,165,233,0.05);
      border-color: var(--blue);
      color: var(--blue);
      border-radius: 6px;
    }

    .alert.error {
      background: rgba(255,45,85,0.06);
      border-color: var(--red);
      color: var(--red);
      border-radius: 6px;
    }

    /* ── META GRID ── */
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 10px;
    }

    .meta-card {
      padding: 16px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,0.3);
      position: relative;
      overflow: hidden;
      border-radius: 6px;
      transition: transform 0.2s ease, background 0.2s ease;
    }
    
    .meta-card:hover {
      background: rgba(14,165,233,0.02);
      transform: translateY(-2px);
    }

    .meta-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: var(--border-hot);
      opacity: 0.5;
    }

    .meta-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--text-dim);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .meta-label::before { content: '//'; }

    .meta-value {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.88rem;
      color: var(--text);
      word-break: break-all;
      line-height: 1.5;
    }

    .meta-value.highlight {
      color: var(--blue-dim);
    }

    /* ── UUID BLOCK ── */
    .uuid-strip {
      padding: 12px 16px;
      background: rgba(0,0,0,0.4);
      border: 1px dashed rgba(14,165,233,0.2);
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.78rem;
      color: var(--text-dim);
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      border-radius: 6px;
    }

    .uuid-label {
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-dim);
      flex-shrink: 0;
    }

    .uuid-val {
      color: var(--text-muted);
      word-break: break-all;
    }

    /* ── CTA ── */
    .cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      padding: 13px 24px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
      border-radius: 4px;
    }

    .btn:active {
      transform: scale(0.98);
    }

    .btn-primary {
      background: var(--blue);
      color: #020b07;
    }

    .btn-primary::before {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
      transition: left 300ms;
    }

    .btn-primary:hover::before { left: 100%; }
    .btn-primary:hover { 
      background: #0ea5e9; 
      box-shadow: 0 6px 24px rgba(14,165,233,0.4); 
      transform: translateY(-2px);
    }

    .btn-ghost {
      background: rgba(14,165,233,0.05);
      color: var(--text-muted);
      border: 1px solid rgba(14,165,233,0.4);
    }

    .btn-ghost:hover {
      border-color: var(--blue-muted);
      color: var(--text);
      background: rgba(14,165,233,0.15);
    }

    /* ── HINT ── */
    .hint {
      font-size: 0.72rem;
      color: var(--text-dim);
      line-height: 1.75;
      letter-spacing: 0.05em;
    }

    .hint::before { content: '// '; color: var(--text-dim); }

    /* ── EMPTY STATE ── */
    .empty-state {
      border: 1px dashed rgba(14,165,233,0.12);
      background: rgba(0,0,0,0.2);
      padding: 32px 24px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      border-radius: 8px;
    }

    .empty-icon {
      font-size: 2.4rem;
      opacity: 0.3;
    }

    .empty-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-muted);
      letter-spacing: 0.1em;
    }

    .empty-sub {
      font-size: 0.82rem;
      color: var(--text-dim);
      line-height: 1.75;
      letter-spacing: 0.05em;
      max-width: 380px;
    }

    /* ── FOOTER ── */
    .page-footer {
      padding: 12px 22px;
      border-top: 1px solid var(--border);
      background: rgba(14,165,233,0.02);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 0.65rem;
      color: var(--text-dim);
      letter-spacing: 0.1em;
    }

    .page-footer span { color: var(--text-muted); }

    @media (max-width: 560px) {
      .hero, .content { padding-left: 18px; padding-right: 18px; }
      .topbar { padding: 10px 16px; }
      .hero-title { font-size: 1.8rem; }
    }
  </style>
</head>
<body>

<main class="page">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <div class="logo-mark">⬡</div>
      <div class="logo-name">CYBERVAULT</div>
    </div>
    <div class="topbar-right">
      <div class="sys-chip">MODULE: <span>PAYLOAD_RETRIEVAL</span></div>
      <div class="sys-chip">SYS: <span id="sysTime">--:--:--</span></div>
      <div class="status-pill"><div class="dot"></div>READY</div>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-corner"></div>
    <p class="eyebrow">RECEIVER VIEW</p>
    <h1 class="hero-title">PAYLOAD<br>READY.</h1>
    <p class="hero-sub">
      Verify the file metadata below and initiate download. Link has been authenticated against the UUID registry.
    </p>
  </section>

  <!-- CONTENT -->
  <section class="content">

    <% if (error) { %>
      <div class="alert error">
        <span class="alert-icon">✕</span>
        <span>[ERR] <%= error %></span>
      </div>
    <% } %>

    <% if (file) { %>

      <div class="alert success">
        <span class="alert-icon">✓</span>
        <span>[OK] Link verified. UUID authenticated. Payload cleared for download.</span>
      </div>

      <div class="meta-grid">
        <div class="meta-card">
          <div class="meta-label">STORED_FILENAME</div>
          <div class="meta-value"><%= file.filename %></div>
        </div>
        <div class="meta-card">
          <div class="meta-label">ORIGINAL_NAME</div>
          <div class="meta-value"><%= file.originalName || file.filename %></div>
        </div>
        <div class="meta-card">
          <div class="meta-label">FILE_SIZE</div>
          <div class="meta-value highlight"><%= (file.size / (1024 * 1024)).toFixed(2) %> MB</div>
        </div>
        <div class="meta-card">
          <div class="meta-label">STATUS</div>
          <div class="meta-value highlight">AVAILABLE</div>
        </div>
      </div>

      <div class="uuid-strip">
        <span class="uuid-label">UUID</span>
        <span class="uuid-val"><%= file.uuid %></span>
      </div>

      <div class="cta-row">
        <a class="btn btn-primary" href="<%= downloadLink %>">▼ DOWNLOAD PAYLOAD</a>
        <a class="btn btn-ghost" href="/">← BACK TO NODE</a>
      </div>

      <p class="hint">
        If the download does not initiate, retry the button or forward the UUID back to the sender node for re-verification.
      </p>

    <% } else { %>

      <div class="empty-state">
        <div class="empty-icon">⬡</div>
        <div class="empty-title">PAYLOAD NOT FOUND</div>
        <p class="empty-sub">
          This share link is unavailable, expired, or no longer mapped to a stored file in the registry.
        </p>
        <a class="btn btn-ghost" href="/">← RETURN TO HOME NODE</a>
      </div>

    <% } %>

  </section>

  <!-- FOOTER -->
  <div class="page-footer">
    <div>// backend governs file storage, delivery &amp; auth. receiver view is read-only.</div>
    <span>CYBERVAULT // XFER_PROTOCOL v2.1.0</span>
  </div>

</main>

<script>
  function tick() {
    document.getElementById('sysTime').textContent = new Date().toTimeString().slice(0, 8);
  }
  tick();
  setInterval(tick, 1000);
</script>

</body>
</html>